<AnchorPane styleClass="main-container" stylesheets="@style.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Application.RoleController">
   <children>
      <Pane layoutY="20.0" prefHeight="30.0" prefWidth="800.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
         <children>
            <Label fx:id="movingLabel" styleClass="moving-text" text=" Experience the Future of Travel — Comfort, Safety, and Reliability at your fingertips, Experience the Future of Travel — Comfort, Safety, and Reliability at your fingertips, " />
         </children>
      </Pane>

      <VBox alignment="CENTER" spacing="25.0" AnchorPane.bottomAnchor="80.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="60.0">
         <children>
            <StackPane>
               <children>
                  <ImageView fx:id="logoImage" fitHeight="130.0" fitWidth="130.0" pickOnBounds="true" styleClass="logo-view">
                     <image>
                        <Image url="file:/C:/Users/Armaghan/OneDrive/Desktop/BUS%20System/images%20(1).jpg" />
                     </image>
                     <clip>
                        <Circle centerX="65.0" centerY="65.0" radius="65.0" />
                     </clip>
                  </ImageView>
               </children>
            </StackPane>

            <VBox alignment="CENTER" spacing="8.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="title-text" text="BUS MANAGEMENT SYSTEM" />
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="subtitle-text" text="Please select your role to continue" />
               </children>
            </VBox>
            
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button fx:id="managerBtn" mnemonicParsing="false" onAction="#handleManager" styleClass="role-button, manager-btn" text="2️⃣ MANAGER" />
                  <Button fx:id="userBtn" mnemonicParsing="false" onAction="#handleUser" styleClass="role-button, user-btn" text="3️⃣ PASSENGER" />
               </children>
            </HBox>

            <VBox alignment="CENTER">
               <children>
                  <Button fx:id="adminBtn" mnemonicParsing="false" onAction="#handleAdmin" styleClass="role-button, admin-btn, admin-row-style" text="1️⃣ ADMIN" />
               </children>
            </VBox>
         </children>
      </VBox>

      <HBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.rightAnchor="20.0">
         <children>
            <Label styleClass="contact-info" text="📧 armaghanmalik81@gmail.com" />
            <Label styleClass="contact-info" text="📞 +91 305 5356221" />
         </children>
