<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="TOP_CENTER" prefHeight="700.0" prefWidth="950.0" spacing="15" style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Application.BookingController">
   <padding>
      <Insets bottom="20.0" left="50.0" right="50.0" top="25.0" />
   </padding>
   <children>
      <VBox maxWidth="850.0" spacing="5">
         <children>
            <Text fill="WHITE" text="Book Your Journey">
               <font><Font name="System Bold" size="26.0" /></font>
            </Text>
            <Text fill="#94a3b8" text="Select your route and find the best available buses." />
         </children>
      </VBox>

      <HBox alignment="CENTER" maxWidth="850.0" prefHeight="95.0" spacing="20" style="-fx-background-color: #1e293b; -fx-background-radius: 15; -fx-padding: 15;">
         <children>
            <VBox spacing="5">
               <Label style="-fx-font-weight: bold;" text="From" textFill="WHITE" />
               <ComboBox fx:id="fromCity" prefHeight="35.0" prefWidth="180.0" promptText="Select Origin" style="-fx-background-color: #0f172a; -fx-text-fill: white;" />
            </VBox>
            <VBox spacing="5">
               <Label style="-fx-font-weight: bold;" text="To" textFill="WHITE" />
               <ComboBox fx:id="toCity" prefHeight="35.0" prefWidth="180.0" promptText="Select Destination" style="-fx-background-color: #0f172a; -fx-text-fill: white;" />
            </VBox>
            <VBox spacing="5">
               <Label style="-fx-font-weight: bold;" text="Date" textFill="WHITE" />
               <DatePicker fx:id="travelDate" prefHeight="35.0" prefWidth="180.0" style="-fx-control-inner-background: #0f172a;" />
            </VBox>
            <Button fx:id="searchBtn" onAction="#handleSearchBuses" prefHeight="38.0" prefWidth="130.0" style="-fx-background-color: #38bdf8; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Search">
               <HBox.margin><Insets top="22.0" /></HBox.margin>
            </Button>
         </children>
      </HBox>

      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" maxWidth="850.0" prefHeight="130.0" style="-fx-background: #0f172a; -fx-border-color: #334155; -fx-border-radius: 10; -fx-background-color: #0f172a;">
         <content>
            <VBox fx:id="busListContainer" spacing="10" style="-fx-background-color: #0f172a; -fx-padding: 10;" />
         </content>
      </ScrollPane>

      <VBox alignment="CENTER" maxWidth="850.0" spacing="10" style="-fx-padding: 15; -fx-background-color: #1e293b; -fx-background-radius: 15; -fx-border-color: #334155; -fx-border-radius: 15;">
          <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="Select Your Seat" textFill="WHITE" />
          <GridPane fx:id="seatGrid" alignment="CENTER" hgap="10" vgap="10">
              <Button prefWidth="45" style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-cursor: hand;" text="1" GridPane.columnIndex="0" GridPane.rowIndex="0" />
              <Button prefWidth="45" style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-cursor: hand;" text="2" GridPane.columnIndex="1" GridPane.rowIndex="0" />
              <Button prefWidth="45" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-cursor: hand;" text="3" GridPane.columnIndex="2" GridPane.rowIndex="0" />
          </GridPane>
      </VBox>

      <VBox maxWidth="850.0" spacing="12" VBox.vgrow="ALWAYS">
         <children>
            <HBox alignment="CENTER_LEFT">
               <children>
                  <Text fill="WHITE" text="My Bookings &amp; Payment">
                     <font><Font name="System Bold" size="20.0" /></font>
                  </Text>
               </children>
            </HBox>
            
            <TableView fx:id="passengerTable" prefHeight="150.0" style="-fx-background-color: #1e293b; -fx-border-color: #334155; -fx-border-radius: 5;">
              <columns>
                <TableColumn fx:id="colBus" prefWidth="160.0" text="Bus Name" />
                <TableColumn fx:id="colRoute" prefWidth="230.0" text="Route" />
                <TableColumn fx:id="colSeat" prefWidth="80.0" text="Seat #" />
                <TableColumn fx:id="colStatus" prefWidth="160.0" text="Status" />
                <TableColumn fx:id="colPayment" prefWidth="215.0" text="Payment Status" />
              </columns>
            </TableView>

            <VBox alignment="CENTER" spacing="10" style="-fx-background-color: #1e293b; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #334155;">
                <Label style="-fx-font-weight: bold;" text="Complete Your Payment" textFill="WHITE" />
                <HBox alignment="CENTER" spacing="15">
                    <children>
                        <Button fx:id="chooseFileBtn" onAction="#handleFileUpload" style="-fx-background-color: #38bdf8; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5; -fx-font-weight: bold;" text="Choose Screenshot" />
                        
                        <Label fx:id="fileNameLabel" prefWidth="200.0" text="No file selected" textFill="#94a3b8" />
                        
                        <Button fx:id="confirmPaymentBtn" disable="true" onAction="#handlePayment" style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 20;" text="Confirm Payment" />
                    </children>
                </HBox>
            </VBox>

            <HBox alignment="CENTER" spacing="25">
               <children>
                  <Button onAction="#goBackToDashboard" prefHeight="35.0" prefWidth="180.0" style="-fx-background-color: #475569; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Back to Dashboard" />
                  <Button onAction="#handleLogout" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Logout" />
               </children>
               <VBox.margin><Insets top="10.0" /></VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>