<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox prefHeight="700.0" prefWidth="1300.0" style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Application.AdminController">
   <children>
      <VBox minWidth="280.0" prefWidth="280.0" spacing="20.0" style="-fx-background-color: #1e293b; -fx-padding: 30;">
         <children>
            <Text fill="WHITE" text="ADMIN PANEL" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
            <Separator opacity="0.2" />
            
            <Button fx:id="btnManageManagers" maxWidth="Infinity" onAction="#showManagerPanel" 
                    style="-fx-background-color: #38bdf8; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 10;" 
                    text="Manage Managers" />
            
            <Button fx:id="btnManageBuses" maxWidth="Infinity" onAction="#handleManageBuses" 
                    style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-cursor: hand; -fx-padding: 10;" 
                    text="Manage Buses" />
            
            <Button fx:id="btnComplaints" maxWidth="Infinity" onAction="#showComplaintsPanel" 
                    style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-cursor: hand; -fx-padding: 10;" 
                    text="Complaints" />
            
            <Region VBox.vgrow="ALWAYS" />
            <Button onAction="#handleLogout" maxWidth="Infinity" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 10;" text="Logout" />
         </children>
      </VBox>

      <StackPane HBox.hgrow="ALWAYS">
         <children>
            <VBox fx:id="managerPanel" spacing="25.0" style="-fx-padding: 40;">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="20">
                      <children>
                          <Text fill="WHITE" text="Managers" style="-fx-font-size: 32px; -fx-font-weight: bold;" />
                          <Region HBox.hgrow="ALWAYS" />
                          <TextField fx:id="searchField" promptText="🔍 Search..." style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-pref-width: 300;" />
                      </children>
                  </HBox>
                  <HBox spacing="10" style="-fx-background-color: #1e293b; -fx-padding: 15; -fx-background-radius: 10;">
                     <children>
                        <TextField fx:id="mName" promptText="Name" HBox.hgrow="ALWAYS" />
                        <TextField fx:id="mEmail" promptText="Email" HBox.hgrow="ALWAYS" />
                        <TextField fx:id="mPass" promptText="Password" HBox.hgrow="ALWAYS" />
                        <TextField fx:id="mPhone" promptText="Phone" HBox.hgrow="ALWAYS" />
                        <Button onAction="#createManager" style="-fx-background-color: #10b981; -fx-text-fill: white;" text="Add" />
                     </children>
                  </HBox>
                  <TableView fx:id="managerTable" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="colName" text="Name" prefWidth="200" />
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="200" />
                        <TableColumn fx:id="colPhone" text="Phone" prefWidth="150" />
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="100" />
                        <TableColumn fx:id="colAction" text="Action" prefWidth="150" />
                     </columns>
                  </TableView>
               </children>
            </VBox>

            <VBox fx:id="busPanel" spacing="25.0" visible="false" style="-fx-padding: 40; -fx-background-color: #0f172a;">
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <children>
                            <Text fill="WHITE" text="Bus Schedules" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" />
                            <Region HBox.hgrow="ALWAYS" />
                            <TextField fx:id="busSearchField" promptText="🔍 Search Bus Name..." 
                                       style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-border-color: #38bdf8; -fx-border-radius: 5; -fx-pref-width: 250;" />
                        </children>
                    </HBox>

                    <VBox spacing="15" style="-fx-background-color: #1e293b; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);">
                        <children>
                            <GridPane hgap="15" vgap="15">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="25" />
                                    <ColumnConstraints percentWidth="25" />
                                    <ColumnConstraints percentWidth="25" />
                                    <ColumnConstraints percentWidth="25" />
                                </columnConstraints>
                                <children>
                                    <TextField fx:id="busNameField" promptText="Bus Name (e.g. Faisal Movers)" GridPane.columnIndex="0" />
                                    <TextField fx:id="busNumberField" promptText="Plate # (e.g. ABC-123)" GridPane.columnIndex="1" />
                                    <TextField fx:id="sourceField" promptText="From" GridPane.columnIndex="2" />
                                    <TextField fx:id="destField" promptText="To" GridPane.columnIndex="3" />
                                </children>
                            </GridPane>

                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <children>
                                    <ComboBox fx:id="busTypeCombo" promptText="Bus Type" prefWidth="150" />
                                    <HBox spacing="5" alignment="CENTER_LEFT" style="-fx-background-color: #0f172a; -fx-padding: 5; -fx-background-radius: 5;">
                                        <children>
                                            <Spinner fx:id="hourSpinner" prefWidth="65" />
                                            <Text fill="#94a3b8" text=":" />
                                            <Spinner fx:id="minuteSpinner" prefWidth="65" />
                                            <ComboBox fx:id="amPmCombo" prefWidth="75" />
                                        </children>
                                    </HBox>
                                    <DatePicker fx:id="datePicker" prefWidth="150" />
                                    <TextField fx:id="priceField" promptText="Price (Rs.)" prefWidth="120" style="-fx-border-color: #10b981; -fx-border-radius: 5;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button fx:id="addBusBtn" onAction="#handleAddBus" prefWidth="110" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Add Bus" />
                                    <Button fx:id="updateBusBtn" onAction="#handleUpdateBus" prefWidth="110" style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Update Bus" />
                                    <Button onAction="#handleDeleteBus" prefWidth="110" text="Delete Bus" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <TableView fx:id="adminBusTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10; -fx-overflow-x: hidden;">
                        <columns>
                            <TableColumn fx:id="colBus" text="Bus Name" prefWidth="180" />
                            <TableColumn fx:id="colRoute" text="Route (From - To)" prefWidth="250" />
                            <TableColumn fx:id="colTime" text="Departure Time" prefWidth="130" />
                            <TableColumn fx:id="colDate" text="Date" prefWidth="120" />
                            <TableColumn fx:id="colPrice" text="Ticket Price (Rs.)" prefWidth="130" />
                            <TableColumn fx:id="colBusAction" text="Actions" prefWidth="150" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </children>
            </VBox>
         </children>
      </StackPane>
   </children>
</HBox>